#pragma once

#include <chrono>
#include <cstdint>

namespace phosphor::modbus::rtu
{

inline constexpr auto modbusRTUTimeout =
    std::chrono::microseconds(@MODBUS_RTU_TIMEOUT_MICROSECONDS@);

inline constexpr auto defaultSensorPollInterval =
    std::chrono::seconds(@SENSOR_POLL_INTERVAL_SECONDS@);

inline constexpr auto inventoryProbeInterval =
    std::chrono::seconds(@INVENTORY_PROBE_INTERVAL_SECONDS@);

inline constexpr auto inventoryDormantProbeInterval =
    std::chrono::seconds(@INVENTORY_DORMANT_PROBE_INTERVAL_SECONDS@);

inline constexpr uint16_t maxRegisterSpanLength =
    @MAX_REGISTER_SPAN_LENGTH@;

inline constexpr auto deviceCleanupInterval =
    std::chrono::seconds(@DEVICE_CLEANUP_INTERVAL_SECONDS@);

} // namespace phosphor::modbus::rtu
