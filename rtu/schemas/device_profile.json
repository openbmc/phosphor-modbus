{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ModbusRTUDeviceProfile",
    "type": "object",
    "required": [
        "DeviceType",
        "DeviceModel",
        "Parity",
        "BaudRate",
        "ProbeRegister"
    ],
    "additionalProperties": false,
    "properties": {
        "DeviceType": {
            "type": "string",
            "enum": [
                "BatteryBackupUnit",
                "CapacitorBankUnit",
                "FlowMeter",
                "HeatExchanger",
                "PowerMonitorModule",
                "PowerShelf",
                "PowerSupplyUnit",
                "ReservoirPumpUnit",
                "Valve"
            ]
        },
        "DeviceModel": {
            "type": "string",
            "enum": [
                "Artesyn7000552480000",
                "Artesyn7000552531000",
                "Artesyn7000555240000",
                "BelimoEV200ARXE",
                "Danfoss003Z8540",
                "DeltaBBUBC100AE000",
                "DeltaBBUBS723AE000",
                "DeltaBBUBU123AE000",
                "DeltaECD17020037",
                "DeltaECD27010006",
                "DeltaECD68000047",
                "DeltaECD68000049",
                "DeltaECD70000017",
                "DeltaECD70000020",
                "DeltaRDF040DSS5193E0",
                "PanasonicBJA3C0002A",
                "PanasonicBJBPM103A",
                "PanasonicBJBSB103A"
            ]
        },
        "Parity": {
            "type": "string",
            "enum": ["None", "Even", "Odd"]
        },
        "BaudRate": {
            "type": "integer"
        },
        "ProbeRegister": {
            "type": "object",
            "required": ["Offset", "Size", "ExpectedValue"],
            "additionalProperties": false,
            "properties": {
                "Offset": { "type": "integer" },
                "Size": { "type": "integer" },
                "ExpectedValue": {
                    "oneOf": [{ "type": "integer" }, { "type": "string" }]
                }
            }
        },
        "InventoryRegisters": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["Type", "Offset", "Size"],
                "additionalProperties": false,
                "properties": {
                    "Type": {
                        "type": "string",
                        "enum": [
                            "BuildDate",
                            "Manufacturer",
                            "Model",
                            "PartNumber",
                            "SerialNumber",
                            "SparePartNumber"
                        ]
                    },
                    "Offset": { "type": "integer" },
                    "Size": { "type": "integer" }
                }
            }
        },
        "SensorRegisters": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["Name", "Type", "Offset", "Size", "Format"],
                "additionalProperties": false,
                "properties": {
                    "Name": { "type": "string" },
                    "Type": {
                        "type": "string",
                        "enum": [
                            "FanTach",
                            "LiquidFlow",
                            "Power",
                            "Pressure",
                            "Temperature",
                            "Voltage",
                            "Current",
                            "Airflow",
                            "Altitude",
                            "Energy",
                            "Frequency",
                            "Humidity",
                            "Utilization",
                            "Valve",
                            "Charge"
                        ]
                    },
                    "Offset": { "type": "integer" },
                    "Size": { "type": "integer" },
                    "Precision": { "type": "integer", "default": 0 },
                    "Scale": { "type": "number", "default": 1.0 },
                    "Shift": { "type": "number", "default": 0.0 },
                    "IsSigned": { "type": "boolean", "default": false },
                    "Format": {
                        "type": "string",
                        "enum": ["FloatingPoint", "Integer"]
                    }
                }
            }
        },
        "StatusRegisters": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["Offset", "Bits"],
                "additionalProperties": false,
                "properties": {
                    "Name": { "type": "string" },
                    "Offset": { "type": "integer" },
                    "Bits": {
                        "type": "array",
                        "items": {
                            "type": "object",
                            "required": [
                                "Name",
                                "Type",
                                "BitPosition",
                                "Value"
                            ],
                            "additionalProperties": false,
                            "properties": {
                                "Name": { "type": "string" },
                                "Type": {
                                    "type": "string",
                                    "enum": [
                                        "ControllerFailure",
                                        "FanFailure",
                                        "FilterFailure",
                                        "PowerFault",
                                        "PumpFailure",
                                        "LeakDetectedCritical",
                                        "LeakDetectedWarning",
                                        "SensorFailure",
                                        "SensorReadingCritical",
                                        "SensorReadingWarning"
                                    ]
                                },
                                "BitPosition": { "type": "integer" },
                                "Value": { "type": "boolean" }
                            }
                        }
                    }
                }
            }
        },
        "FirmwareRegisters": {
            "type": "array",
            "items": {
                "type": "object",
                "required": ["Name", "Type", "Offset", "Size"],
                "additionalProperties": false,
                "properties": {
                    "Name": { "type": "string" },
                    "Type": {
                        "type": "string",
                        "enum": ["Version", "Update"]
                    },
                    "Offset": { "type": "integer" },
                    "Size": { "type": "integer" }
                }
            }
        }
    }
}
